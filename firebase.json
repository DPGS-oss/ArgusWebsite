{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/config", "function": "apiConfig" },
      { "source": "/api/auth/sync", "function": "apiAuthSync" },
      { "source": "/api/auth/plans", "function": "apiAuthPlans" },
      { "source": "/api/user/profile", "function": "apiUserProfile" },
      { "source": "/api/payment/create-order", "function": "apiPaymentCreateOrder" },
      { "source": "/api/payment/verify", "function": "apiPaymentVerify" },
      { "source": "/api/account/delete", "function": "apiAccountDelete" },
      { "source": "/api/data/load", "function": "apiDataLoad" },
      { "source": "/api/data/save", "function": "apiDataSave" },
      { "source": "/api/data/scan-result", "function": "apiDataScanResult" }
    ],
    "cleanUrls": true
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
